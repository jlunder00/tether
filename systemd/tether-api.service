[Unit]
Description=Tether API Server
After=network.target

[Service]
Type=simple
User=toast
WorkingDirectory=/home/toast/tether
EnvironmentFile=-/home/toast/.tether-config/env
ExecStart=/home/toast/tether/.venv/bin/uvicorn api.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
